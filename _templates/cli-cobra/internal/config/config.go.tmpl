package config

import (
	"os"
	"path/filepath"
	"strings"

	"github.com/spf13/viper"
)

func Load(cfgFile string) {
	// APP_ENV → "env", APP_LOG_LEVEL → "log-level" (hyphens replaced by underscores)
	viper.SetEnvPrefix("APP")
	viper.SetEnvKeyReplacer(strings.NewReplacer("-", "_"))
	viper.AutomaticEnv()

	if cfgFile != "" {
		viper.SetConfigFile(cfgFile)
		_ = viper.ReadInConfig()
		return
	}

	viper.SetConfigName("config")
	viper.SetConfigType("toml")
	if home, err := os.UserHomeDir(); err == nil {
		viper.AddConfigPath(filepath.Join(home, ".{{.Name}}"))
	}
	viper.AddConfigPath(".")
	viper.AddConfigPath("./configs")
	_ = viper.ReadInConfig()

	// Load environment-specific override (e.g. configs/config_development.toml).
	// Keys present in the overlay overwrite the base config.
	// Silently ignored if the file does not exist.
	if env := viper.GetString("env"); env != "" {
		viper.SetConfigName("config_" + env)
		_ = viper.MergeInConfig()
	}
}
