FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION={{.Version}}
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags "-X {{.OrgPrefix}}/{{.Name}}/cmd/cmd/version.Version=${VERSION}" \
    -o /{{.Name}} ./cmd/

FROM gcr.io/distroless/static-debian12
COPY --from=builder /{{.Name}} /{{.Name}}
ENTRYPOINT ["/{{.Name}}"]
